{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "interactive-drive: raster GUI",
      "type": "debugpy",
      "request": "launch",
      "module": "interactive-drive",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "args": [
        "--scene",
        "${workspaceFolder}/assets/scenes/clipgt-01d503d4-449b-46fc-8d78-9085e70d3554.usdz",
        "--backend",
        "raster"
      ]
    },
    {
      "name": "interactive-drive: world_model GUI",
      "type": "debugpy",
      "request": "launch",
      "module": "interactive-drive",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "args": [
        "--scene",
        "${workspaceFolder}/assets/scenes/clipgt-01d503d4-449b-46fc-8d78-9085e70d3554.usdz",
        "--backend",
        "world_model",
        "--manifest",
        "${workspaceFolder}/configs/example_world_model.yaml"
      ]
    },
    {
      "name": "interactive-drive: world_model GUI (official hdmap first chunk)",
      "type": "debugpy",
      "request": "launch",
      "module": "interactive-drive",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "args": [
        "--scene",
        "${workspaceFolder}/assets/scenes/clipgt-01d503d4-449b-46fc-8d78-9085e70d3554.usdz",
        "--backend",
        "world_model",
        "--manifest",
        "${workspaceFolder}/configs/example_world_model.yaml",
        "--official-hdmap-dir",
        "${workspaceFolder}/debug-trace/replay-from-recording-v4/live/camera_front_wide_120fov"
      ]
    }
  ]
}
